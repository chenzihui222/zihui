---
const name = "ZIHUI CHEN";
const role = "Independent Researcher & Builder";
const tagline = "Exploring technology, venture capital, and building tools that matter.";
---

<section class="relative overflow-hidden">
	<!-- Subtle geometric grid background -->
	<div class="geo-bg"></div>

	<div class="max-w-[1400px] mx-auto px-8 md:px-12 pt-16 pb-20">
		<nav class="flex items-center justify-between mb-20 animate-fade-up">
			<div class="flex items-center gap-3">
				<span class="nav-dot"></span>
				<span class="text-[0.85rem] font-bold tracking-[0.12em] uppercase text-text-primary">
					ZIHUICHEN.COM
				</span>
			</div>
			<div class="flex items-center gap-6">
				<a href="#projects" class="text-[0.8rem] font-medium text-text-secondary hover:text-accent transition-colors duration-150 tracking-wide uppercase">Projects</a>
				<a href="#about" class="text-[0.8rem] font-medium text-text-secondary hover:text-accent transition-colors duration-150 tracking-wide uppercase">About</a>
				<a href="https://vc.zihuichen.com" target="_blank" rel="noopener noreferrer" class="text-[0.8rem] font-medium text-text-secondary hover:text-accent transition-colors duration-150 tracking-wide uppercase">VC Radar</a>
				<a
					href="https://github.com/chenzihui222"
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-center gap-2 px-4 py-[6px] bg-card border border-border rounded-[8px] text-[0.8rem] font-medium text-text-secondary hover:border-accent hover:text-accent transition-all duration-150"
				>
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					GitHub
				</a>
			</div>
		</nav>

		<div class="max-w-3xl">
			<div class="animate-fade-up stagger-1">
				<span class="inline-block font-mono text-[0.72rem] font-medium text-accent tracking-[0.15em] uppercase mb-6 px-3 py-1 bg-accent-glow rounded-[6px] border border-accent/20">
					researcher / developer / builder
				</span>
			</div>

			<h1 class="text-[3.5rem] md:text-[5rem] font-extrabold tracking-[-0.04em] leading-[0.95] text-text-primary mb-6 animate-fade-up stagger-2">
				{name}<span class="text-accent">.</span>
			</h1>

			<p class="text-[1.15rem] md:text-[1.3rem] font-light text-text-secondary leading-relaxed max-w-xl mb-10 animate-fade-up stagger-3">
				{tagline}
			</p>

			<div class="flex items-center gap-4 animate-fade-up stagger-4">
				<a href="#projects" class="group inline-flex items-center gap-2 px-6 py-3 bg-accent text-white text-[0.85rem] font-semibold rounded-[8px] hover:bg-[#e5730d] transition-all duration-150 shadow-[0_4px_12px_rgba(243,128,32,0.3)] hover:shadow-[0_6px_20px_rgba(243,128,32,0.4)] hover:-translate-y-[2px] active:translate-y-0">
					View Projects
					<svg class="w-4 h-4 transition-transform duration-150 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
				</a>
				<a href="#contact" class="inline-flex items-center px-6 py-3 bg-card border border-border text-text-secondary text-[0.85rem] font-medium rounded-[8px] hover:border-border-hover hover:text-text-primary transition-all duration-150">
					Get in Touch
				</a>
			</div>
		</div>

		<!-- Dynamic stat badges -->
		<div class="flex flex-wrap items-center gap-3 mt-16 animate-fade-up stagger-5">
			<div class="stat-badge">
				<span class="stat-dot bg-[#059669]"></span>
				<span class="font-mono text-[0.72rem] text-text-muted">3+ Open Source Projects</span>
			</div>
			<div class="stat-badge">
				<span class="stat-dot bg-[#2563eb]"></span>
				<span class="font-mono text-[0.72rem] text-text-muted">VC & Tech Research</span>
			</div>
			<div class="stat-badge">
				<span class="stat-dot bg-[#7c3aed]"></span>
				<span class="font-mono text-[0.72rem] text-text-muted">Full-Stack Development</span>
			</div>
		</div>
	</div>
</section>

<style>
	.geo-bg {
		position: absolute;
		inset: 0;
		background-image:
			radial-gradient(circle at 85% 20%, rgba(243, 128, 32, 0.04) 0%, transparent 50%),
			radial-gradient(circle at 15% 80%, rgba(37, 99, 235, 0.03) 0%, transparent 40%);
		pointer-events: none;
	}

	.nav-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: #f38020;
		animation: pulse 3s ease-in-out infinite;
	}

	.stat-badge {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 6px 14px;
		background: #ffffff;
		border: 1px solid #e0e3e8;
		border-radius: 8px;
		transition: all 150ms ease;
	}

	.stat-badge:hover {
		border-color: #c5cad3;
		transform: translateY(-1px);
	}

	.stat-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		nav {
			flex-direction: column;
			align-items: flex-start;
			gap: 16px;
		}
		h1 {
			font-size: 2.8rem !important;
		}
	}
