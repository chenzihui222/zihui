---
interface Props {
	title?: string;
	description?: string;
}
const { title = 'Zihui Chen', description = 'Independent Researcher & Builder' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="bg-base text-text-primary font-display antialiased leading-relaxed">
		<div class="accent-bar"></div>

		<!-- Interactive background canvas -->
		<canvas id="bg-canvas"></canvas>

		<!-- Mouse-following gradient glow -->
		<div id="mouse-glow"></div>

		<slot />

		<style is:global>
			#bg-canvas {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: 0;
				pointer-events: none;
			}

			#mouse-glow {
				position: fixed;
				width: 600px;
				height: 600px;
				border-radius: 50%;
				pointer-events: none;
				z-index: 0;
				background: radial-gradient(
					circle,
					rgba(243, 128, 32, 0.06) 0%,
					rgba(243, 128, 32, 0.02) 30%,
					rgba(37, 99, 235, 0.015) 60%,
					transparent 100%
				);
				transform: translate(-50%, -50%);
				transition: left 0.3s ease-out, top 0.3s ease-out, opacity 0.4s ease;
				opacity: 0;
				will-change: left, top;
			}

			#mouse-glow.active {
				opacity: 1;
			}

			/* Ensure all content sits above background */
			body > *:not(#bg-canvas):not(#mouse-glow):not(.accent-bar) {
				position: relative;
				z-index: 1;
			}

			.accent-bar {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				height: 2px;
				background: #f38020;
				z-index: 9999;
			}

			@keyframes fadeUp {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@keyframes fadeIn {
				from { opacity: 0; }
				to { opacity: 1; }
			}

			@keyframes slideInLeft {
				from {
					opacity: 0;
					transform: translateX(-30px);
				}
				to {
					opacity: 1;
					transform: translateX(0);
				}
			}

			@keyframes countUp {
				from { opacity: 0; transform: scale(0.8); }
				to { opacity: 1; transform: scale(1); }
			}

			@keyframes expandWidth {
				from { width: 0; }
				to { width: 100%; }
			}

			@keyframes pulse {
				0%, 100% { box-shadow: 0 0 12px rgba(243, 128, 32, 0.15); }
				50% { box-shadow: 0 0 24px rgba(243, 128, 32, 0.35); }
			}

			.animate-fade-up {
				opacity: 0;
				animation: fadeUp 0.6s ease forwards;
			}

			.animate-slide-left {
				opacity: 0;
				animation: slideInLeft 0.6s ease forwards;
			}

			.stagger-1 { animation-delay: 0.05s; }
			.stagger-2 { animation-delay: 0.1s; }
			.stagger-3 { animation-delay: 0.15s; }
			.stagger-4 { animation-delay: 0.2s; }
			.stagger-5 { animation-delay: 0.25s; }
			.stagger-6 { animation-delay: 0.3s; }
			.stagger-7 { animation-delay: 0.35s; }
			.stagger-8 { animation-delay: 0.4s; }

			/* Scroll-triggered reveal */
			.reveal {
				opacity: 0;
				transform: translateY(24px);
				transition: opacity 0.7s ease, transform 0.7s ease;
			}
			.reveal.visible {
				opacity: 1;
				transform: translateY(0);
			}

			/* Selection color */
			::selection {
				background: rgba(243, 128, 32, 0.2);
				color: #1a1e2c;
			}
		</style>

		<script>
			// ============ Interactive Dot Grid + Connection Lines ============
			const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
			const ctx = canvas.getContext('2d')!;

			let width = 0;
			let height = 0;
			let mouseX = -1000;
			let mouseY = -1000;
			let dots: { x: number; y: number; baseX: number; baseY: number; vx: number; vy: number }[] = [];

			const GRID_SPACING = 48;
			const DOT_RADIUS = 1;
			const MOUSE_RADIUS = 180;
			const CONNECTION_RADIUS = 120;
			const PUSH_FORCE = 18;
			const RETURN_SPEED = 0.04;

			function resize() {
				width = canvas.width = window.innerWidth;
				height = canvas.height = window.innerHeight;
				initDots();
			}

			function initDots() {
				dots = [];
				const cols = Math.ceil(width / GRID_SPACING) + 1;
				const rows = Math.ceil(height / GRID_SPACING) + 1;
				const offsetX = (width - (cols - 1) * GRID_SPACING) / 2;
				const offsetY = (height - (rows - 1) * GRID_SPACING) / 2;

				for (let r = 0; r < rows; r++) {
					for (let c = 0; c < cols; c++) {
						const x = offsetX + c * GRID_SPACING;
						const y = offsetY + r * GRID_SPACING;
						dots.push({ x, y, baseX: x, baseY: y, vx: 0, vy: 0 });
					}
				}
			}

			function animate() {
				ctx.clearRect(0, 0, width, height);

				// Update dot positions — mouse pushes them, they spring back
				for (const dot of dots) {
					const dx = dot.x - mouseX;
					const dy = dot.y - mouseY;
					const dist = Math.sqrt(dx * dx + dy * dy);

					if (dist < MOUSE_RADIUS && dist > 0) {
						const force = (1 - dist / MOUSE_RADIUS) * PUSH_FORCE;
						const angle = Math.atan2(dy, dx);
						dot.vx += Math.cos(angle) * force * 0.06;
						dot.vy += Math.sin(angle) * force * 0.06;
					}

					// Spring back to base position
					dot.vx += (dot.baseX - dot.x) * RETURN_SPEED;
					dot.vy += (dot.baseY - dot.y) * RETURN_SPEED;

					// Damping
					dot.vx *= 0.88;
					dot.vy *= 0.88;

					dot.x += dot.vx;
					dot.y += dot.vy;
				}

				// Draw connection lines near mouse
				for (let i = 0; i < dots.length; i++) {
					const a = dots[i];
					const distToMouse = Math.sqrt((a.x - mouseX) ** 2 + (a.y - mouseY) ** 2);
					if (distToMouse > MOUSE_RADIUS * 1.5) continue;

					for (let j = i + 1; j < dots.length; j++) {
						const b = dots[j];
						const distB = Math.sqrt((b.x - mouseX) ** 2 + (b.y - mouseY) ** 2);
						if (distB > MOUSE_RADIUS * 1.5) continue;

						const d = Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2);
						if (d < CONNECTION_RADIUS) {
							const alpha = (1 - d / CONNECTION_RADIUS) * 0.15 *
								Math.min(1, 1 - Math.max(distToMouse, distB) / (MOUSE_RADIUS * 1.5));
							ctx.beginPath();
							ctx.moveTo(a.x, a.y);
							ctx.lineTo(b.x, b.y);
							ctx.strokeStyle = `rgba(243, 128, 32, ${alpha})`;
							ctx.lineWidth = 0.6;
							ctx.stroke();
						}
					}
				}

				// Draw dots
				for (const dot of dots) {
					const dx = dot.x - mouseX;
					const dy = dot.y - mouseY;
					const dist = Math.sqrt(dx * dx + dy * dy);

					let alpha = 0.12;
					let radius = DOT_RADIUS;
					let color = '146, 155, 176'; // text-muted color

					if (dist < MOUSE_RADIUS) {
						const proximity = 1 - dist / MOUSE_RADIUS;
						alpha = 0.12 + proximity * 0.6;
						radius = DOT_RADIUS + proximity * 1.8;
						// Blend from gray to orange as mouse gets closer
						const r = Math.round(146 + (243 - 146) * proximity);
						const g = Math.round(155 + (128 - 155) * proximity);
						const b = Math.round(176 + (32 - 176) * proximity);
						color = `${r}, ${g}, ${b}`;
					}

					ctx.beginPath();
					ctx.arc(dot.x, dot.y, radius, 0, Math.PI * 2);
					ctx.fillStyle = `rgba(${color}, ${alpha})`;
					ctx.fill();
				}

				requestAnimationFrame(animate);
			}

			// Mouse tracking
			const glow = document.getElementById('mouse-glow')!;

			document.addEventListener('mousemove', (e) => {
				mouseX = e.clientX;
				mouseY = e.clientY;

				glow.style.left = e.clientX + 'px';
				glow.style.top = e.clientY + 'px';
				glow.classList.add('active');
			});

			document.addEventListener('mouseleave', () => {
				mouseX = -1000;
				mouseY = -1000;
				glow.classList.remove('active');
			});

			// Init
			window.addEventListener('resize', resize);
			resize();
			animate();

			// ============ Scroll Reveal Observer ============
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
						}
					});
				},
				{ threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
			);
			document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
		</script>
	</body>
</html>
